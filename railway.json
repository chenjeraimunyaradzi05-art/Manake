{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=manake-web"
  },
  "deploy": {
    "startCommand": "sh -lc 'npx prisma migrate deploy --schema=manake-web/prisma/schema.prisma || true; npm run start --workspace=manake-web'",
    "region": "us-west2",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
