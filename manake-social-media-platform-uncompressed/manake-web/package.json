{
  "name": "manake-web",
  "version": "1.0.0",
  "type": "module",
  "description": "Manake Recovery Platform - Web Application",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "next dev",
    "dev:server": "npx tsx src/server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "npm run db:prepare && next build",
    "build:server": "tsc --project tsconfig.server.json",
    "start": "node dist/server/index.js",
    "start:next": "next start",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:prepare": "node scripts/prepare-postgres-db.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@netlify/database": "^1.0.0",
    "@prisma/client": "^5.19.0",
    "@types/node": "^20.14.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "next": "^14.2.0",
    "nodemailer": "^6.9.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.5",
    "react-hot-toast": "^2.4.1",
    "react-query": "^3.39.3",
    "react-router-dom": "^6.23.1",
    "serverless-http": "^3.2.0",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "stripe": "^15.8.0",
    "tailwind-merge": "^2.3.0",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "playwright": "^1.44.0",
    "postcss": "^8.4.38",
    "prisma": "^5.19.0",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.12.2",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "recovery",
    "mentorship",
    "social-platform",
    "addiction-support",
    "community",
    "react",
    "typescript",
    "express",
    "prisma"
  ],
  "author": "Manake Recovery Platform",
  "license": "MIT",
  "private": true
}
